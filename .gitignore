# Dependencies
node_modules/

# Python cache
__pycache__/
*.pyc

# Output (generated by orchestrator runs)
output/

# Logs (regenerated at runtime)
.brain/logs/*.log

# Worker state (regenerated at runtime)
.brain/workers/*.json

# Signals (ephemeral markers)
.brain/signals/*
!.brain/signals/.gitkeep

# Runtime files (regenerated each run)
.brain/plan.md
.brain/session-notes.md

# User-specific settings
.claude/settings.local.json

# Temp files
*.tmp
.DS_Store

# Secrets
.env
.env.*
